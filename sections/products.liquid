    badge:"مضمون",
    rating:4.7,
    reviews:61,
    city:"الدمام",
    warranty:"ضمان 3 أشهر",
    delivery:"استلام أو شحن",
    seller:"بائع موثق",
    meta:"13 إنش · 8GB RAM · 256GB SSD · نظيف جدًا",
    check:"تم فحص البطارية، لوحة المفاتيح، الشاشة، المنافذ، والنظام",
    image:"https://images.unsplash.com/photo-1517336714731-489689fd1ca8?q=80&w=900"
  },
  {
    id:4,
    name:"iPad Pro 11 M2",
    price:2299,
    oldPrice:2799,
    category:"electronics",
    type:"used",
    condition:"مستعمل",
